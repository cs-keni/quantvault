# Copy to .env and fill in real values for local development.
# .env is gitignored — never commit secrets.

# --- Postgres (also used to build DATABASE_URL in docker-compose.yml) ---
# "qv" matches the Settings defaults in app/core/config.py, so a fresh
# `cp .env.example .env` works for both `docker compose up` and running the
# backend/tests directly via .venv against the published db port. Fine for
# local dev (localhost-only); rotate for anything shared.
DB_PASSWORD=qv

# --- Backend ---
# Full async SQLAlchemy URL. Compose injects DB_PASSWORD into this for you;
# set it directly when running the backend outside Docker.
DATABASE_URL=postgresql+asyncpg://qv:qv@localhost:5432/quantvault
REDIS_URL=redis://localhost:6379/0

# JWT signing key — generate with `openssl rand -hex 32`. Never reuse across environments.
SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
